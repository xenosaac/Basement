# Database — Vercel Postgres auto-injects POSTGRES_URL
# For local dev, use DATABASE_URL with local PostgreSQL
DATABASE_URL="postgresql://youruser@localhost:5432/basement"
# POSTGRES_URL is auto-set by Vercel when you connect a Postgres store

# Admin + Cron secrets (set any random string)
ADMIN_SECRET="change-me"
CRON_SECRET="change-me"

# JWT for session cookies (set any random string, 32+ chars)
JWT_SECRET="change-me-to-something-long-and-random"

# Server wallet private key for faucet (optional)
# FAUCET_PRIVATE_KEY="0x..."

# Aptos testnet — filled in Session C after Move publish (2026-04-22)
# Run `aptos init --profile basement-admin --network testnet`, then publish
# `move/basement/` with `--named-addresses basement=<your-addr>`. Copy the
# deployer address into both _MODULE_ADDRESS vars, query
# virtual_usd::get_metadata_address for _METADATA_ADDRESS, and (on v0 testnet)
# reuse the same addr for ADMIN_ADDRESS.
APTOS_NETWORK=testnet
APTOS_FULLNODE_URL=https://fullnode.testnet.aptoslabs.com/v1
APTOS_INDEXER_URL=https://api.testnet.aptoslabs.com/v1/graphql
NEXT_PUBLIC_APTOS_CHAIN_ID=2
BASEMENT_MODULE_ADDRESS=
NEXT_PUBLIC_BASEMENT_MODULE_ADDRESS=
VIRTUAL_USD_METADATA_ADDRESS=
NEXT_PUBLIC_VIRTUAL_USD_METADATA_ADDRESS=
ADMIN_ADDRESS=
NEXT_PUBLIC_ADMIN_ADDRESS=

# Pyth Hermes channel + feed ids — CHAIN-SPECIFIC:
#   Aptos TESTNET → hermes-beta + beta feed ids (guardian set 0, matches
#                   testnet Wormhole deployment).
#   Aptos MAINNET → hermes (stable) + stable feed ids (guardian set 5).
# Using stable channel VAAs on Aptos testnet aborts at
# wormhole::vaa::parse_and_verify with 0x6507 because testnet Wormhole
# only has guardian_set[0]. Pick the pair below that matches your target
# chain; feed ids are PUBLIC constants so we mirror them into NEXT_PUBLIC_.
PYTH_HERMES_URL=https://hermes-beta.pyth.network
PYTH_BTC_FEED_ID=0xf9c0172ba10dfa4d19088d94f5bf61d3b54d5bd7483a322a982e1373ee8ea31b
PYTH_ETH_FEED_ID=0xca80ba6dc32e08d06f1aa886011eed1d77c77be9eb761cc10d72b7d0a2fd57a6
NEXT_PUBLIC_PYTH_BTC_FEED_ID=0xf9c0172ba10dfa4d19088d94f5bf61d3b54d5bd7483a322a982e1373ee8ea31b
NEXT_PUBLIC_PYTH_ETH_FEED_ID=0xca80ba6dc32e08d06f1aa886011eed1d77c77be9eb761cc10d72b7d0a2fd57a6
# XAU/USD (gold spot) — used by the Commodity tab's xau-1h group.
PYTH_XAU_FEED_ID=0x30a19158f5a54c0adf8fb7560627343f22a1bc852b89d56be1accdc5dbf96d0e
NEXT_PUBLIC_PYTH_XAU_FEED_ID=0x30a19158f5a54c0adf8fb7560627343f22a1bc852b89d56be1accdc5dbf96d0e
# Mainnet alternates (kept for reference — swap in when deploying there):
#   PYTH_HERMES_URL=https://hermes.pyth.network
#   PYTH_BTC_FEED_ID=0xe62df6c8b4a85fe1a67db44dc12de5db330f7ac66b72dc658afedf0f4a415b43
#   PYTH_ETH_FEED_ID=0xff61491a931112ddf1bd8147cd1b641375f79f5825126d665480874634fd0ace
#   PYTH_XAU_FEED_ID=0x765d2ba906dbc32ca17cc11f5310a89e9ee1f6420508c63861f2f8ba4ee34bb2

# Resolve path for recurring markets:
#   "oracle" = on-chain Pyth via case_vault::resolve_oracle(case_id, vaa).
#              Fully on-chain, non-custodial. Requires PYTH_HERMES_URL +
#              feed ids to match the target chain's Pyth/Wormhole channel
#              (see block above). This is the production path.
#   "admin"  = admin backend computes outcome off-chain → case_vault::
#              admin_resolve(case_id, outcome). Emergency escape hatch
#              only; admin still CAN NOT move user funds (Move module
#              enforces this), but the outcome bit is trusted.
ORACLE_RESOLVE_MODE=oracle

# Admin + faucet-sponsor private keys — wired in Session D (admin backend +
# sponsor route). v0 testnet uses the SAME key for both roles; v1 will split.
# Retrieve via `cat .aptos/config.yaml | grep private_key` for the
# basement-admin profile. DO NOT commit real values.
APTOS_ADMIN_PRIVATE_KEY=0x_REPLACE_ME
APTOS_FAUCET_ADMIN_PRIVATE_KEY=0x_REPLACE_ME
# Comma-separated list of addresses allowed to hit /api/admin/*. v0 = single
# admin address (the testnet deployer).
ADMIN_ALLOWED_ADDRESSES=0xb3a8d906f99dae8344b2223abc4432d12c134f44473ebcb7bccc4072f55f2ff7
